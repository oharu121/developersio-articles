{
  "permissions": {
    "allow": [
      "WebFetch(domain:www.contentful.com)",
      "Bash(gh auth status)",
      "Bash(git tag v1.0.0)",
      "Bash(git push)",
      "Bash(git push --tags)",
      "Bash(gh issue close*)",
      "Bash(gh api user --jq '.name // .login')",
      "Bash(gh api user --jq '.email // empty')",
      "Bash(gh api user/emails --jq '.[0].email')",
      "Bash(ls -d */)",
      "Bash(gh issue:*)",
      "Bash(git fetch)",
      "Bash(git rev-list --count HEAD..@{u})",
      "Bash(git tag:*)",
      "Bash(gh release:*)"
    ]
  }
}
